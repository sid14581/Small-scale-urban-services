{
  "name": "scms-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "sync-images": "rm -rf public/assets && mkdir -p public/assets && find ../static -maxdepth 1 -type f \\( -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.png' -o -iname '*.webp' \\) -exec cp {} public/assets/ \\;",
    "predev": "npm run sync-images",
    "prebuild": "npm run sync-images",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.8"
  }
}
