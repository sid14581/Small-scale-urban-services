# Django
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-generate-a-unique-secret-key-before-deploy
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# Database
DB_NAME=projectDB
DB_USER=root
DB_PASSWORD=
DB_HOST=db
DB_PORT=3306

# CORS (React dev server + nginx proxy)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# CSRF (Django admin login via nginx on :8080)
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Cache — omit REDIS_URL for locmem (local runserver); Docker Compose sets redis://redis:6379/1
# REDIS_URL=redis://redis:6379/1

# Database connection reuse (seconds)
# DB_CONN_MAX_AGE=600

# Production HTTPS (set DEBUG=False)
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000

# Frontend auth bypass (dev/demo only — rebuild frontend after changing)
# off | mock | mock-staff | citizen | staff
VITE_AUTH_BYPASS=off

# Twilio OTP — choose ONE delivery method:
# Option A (recommended): Twilio Verify — no sender phone number needed
#   Console → Verify → Services → copy Service SID (starts with VA)
TWILIO_VERIFY_SERVICE_SID=
# Option B: Programmable SMS — requires TWILIO_PHONE_NUMBER (Twilio-purchased sender)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OTP rate limit (per user, not per phone — default 10 in DEBUG, 3 in production)
# OTP_RATE_LIMIT=10
# OTP_RATE_WINDOW=900
